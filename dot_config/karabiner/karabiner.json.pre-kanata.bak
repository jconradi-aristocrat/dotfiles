{
    "global": {
        "show_additional_menu_items": true,
        "show_profile_name_in_menu_bar": true
    },
    "profiles": [
        {
            "complex_modifications": {
                "parameters": {
                    "basic.simultaneous_threshold_milliseconds": 200,
                    "basic.to_delayed_action_delay_milliseconds": 250,
                    "basic.to_if_alone_timeout_milliseconds": 250
                },
                "rules": [
                    {
                        "description": "Foundation: caps_lock → Hyper / Esc",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "f19",
                                        "modifiers": ["left_command", "left_control", "left_option", "left_shift"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open layer (Hyper+O → letter)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "o",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "o-mode",
                                            "value": 1
                                        }
                                    }
