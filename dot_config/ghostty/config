# ======================================================
# Ghostty 1.3.x Config
# Optimized for tmux + zsh + nvim
# ======================================================

# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Cursor
cursor-style = block

# Window padding
window-padding-x = 6
window-padding-y = 6

# Scrollback
scrollback-limit = 1000000

# Copy behavior
copy-on-select = false

# Terminal type
term = xterm-256color
