{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# hash: {{ include "Brewfile.darwin" | sha256sum }}
set -euo pipefail
if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew not installed; skipping brew bundle."
  exit 0
fi
brew bundle install --file "{{ .chezmoi.sourceDir }}/Brewfile.darwin"
{{- end -}}
